            </div>

            <h1 className="max-w-4xl text-5xl font-semibold tracking-tight text-[var(--text)] md:text-7xl">
              AI systems for{" "}
              <span className="bg-gradient-to-r from-sky-300 via-cyan-200 to-indigo-300 bg-clip-text text-transparent">
