function Chip({ children }: { children: string }) {
  return (
    <span className="rounded-full border border-white/10 bg-white/[0.07] px-3 py-1 text-xs text-slate-300">
      {children}
    </span>
  );
}

function Reveal({
  children,
  delay = 0,
  className = "",
}: {
  children: React.ReactNode;
  delay?: number;
  className?: string;
}) {
  return (
    <motion.div
      initial={{ opacity: 0, y: 34, filter: "blur(8px)" }}
      whileInView={{ opacity: 1, y: 0, filter: "blur(0px)" }}
      viewport={{ once: true, margin: "-80px" }}
      transition={{ duration: 0.72, delay, ease: "easeOut" }}
      className={className}
    >
      {children}
    </motion.div>
  );
}

function ProjectVisual({ type }: { type: string }) {
  if (type === "forecast") {
    return (
      <div className="relative h-28 overflow-hidden rounded-2xl bg-gradient-to-br from-sky-400/16 to-indigo-400/12 p-4">
        <svg viewBox="0 0 320 110" className="h-full w-full">
          <path d="M10 82 C40 76 56 58 82 66 S132 90 160 58 S214 24 248 42 S292 62 312 28" fill="none" stroke="rgba(125,211,252,.85)" strokeWidth="4" strokeLinecap="round" />
          <path d="M10 92 L312 92" stroke="rgba(255,255,255,.16)" />
          {[52, 104, 156, 208, 260].map((x) => (
            <rect key={x} x={x} y={72 - (x % 55)} width="12" height={20 + (x % 42)} rx="4" fill="rgba(255,255,255,.18)" />
          ))}
        </svg>
      </div>
    );
  }

  if (type === "grid") {
    return (
      <div className="relative h-28 overflow-hidden rounded-2xl bg-gradient-to-br from-cyan-400/12 to-violet-400/16 p-4">
        <div className="grid h-full grid-cols-5 gap-2">
          {Array.from({ length: 20 }).map((_, i) => (
            <motion.div
              key={i}
              animate={{ opacity: [0.28, 0.75, 0.28] }}
              transition={{ duration: 2.2 + (i % 4), repeat: Infinity, delay: i * 0.08 }}
              className="rounded-lg bg-white/15"
            />
          ))}
        </div>
      </div>
    );
  }

  if (type === "control") {
    return (
      <div className="relative h-28 overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-400/14 to-sky-400/12 p-4">
        <svg viewBox="0 0 320 110" className="h-full w-full">
          <path d="M8 55 H78 C104 55 104 30 130 30 H188 C214 30 214 82 240 82 H312" fill="none" stroke="rgba(255,255,255,.22)" strokeWidth="8" strokeLinecap="round" />
          <path d="M8 55 H78 C104 55 104 30 130 30 H188 C214 30 214 82 240 82 H312" fill="none" stroke="rgba(125,211,252,.88)" strokeWidth="3" strokeLinecap="round" />
          {[78, 130, 188, 240].map((x, i) => (
            <circle key={x} cx={x} cy={i < 2 ? 30 + i * 25 : 82 - (i - 2) * 52} r="6" fill="rgba(255,255,255,.82)" />
          ))}
        </svg>
      </div>
    );
  }

  if (type === "energy") {
    return (
      <div className="relative h-28 overflow-hidden rounded-2xl bg-gradient-to-br from-sky-400/12 to-emerald-400/12 p-4">
        <div className="flex h-full items-end gap-2">
          {[42, 58, 34, 76, 50, 82, 62, 44, 72, 88, 56].map((h, i) => (
            <motion.div
              key={i}
              animate={{ height: [`${h * 0.65}%`, `${h}%`, `${h * 0.65}%`] }}
              transition={{ duration: 2.5 + i * 0.1, repeat: Infinity, delay: i * 0.05 }}
              className="w-full rounded-t-lg bg-cyan-200/45"
            />
          ))}
        </div>
      </div>
    );
  }

  return (
    <div className="relative h-28 overflow-hidden rounded-2xl bg-gradient-to-br from-sky-400/14 to-indigo-400/16">
      <svg viewBox="0 0 320 110" className="h-full w-full">
        {[
          [42, 30],
          [96, 72],
          [150, 42],
          [216, 76],
          [270, 36],
          [70, 90],
          [240, 92],
        ].map(([x, y], i) => (
          <g key={i}>
            <circle cx={x} cy={y} r={7 + (i % 3)} fill="rgba(226,246,255,.72)" />
          </g>
        ))}
        <path d="M42 30 L96 72 L150 42 L216 76 L270 36 M96 72 L70 90 M216 76 L240 92" stroke="rgba(125,211,252,.55)" strokeWidth="2.5" />
      </svg>
    </div>
  );
}

function ThemeToggle({ theme, setTheme }: { theme: Theme; setTheme: (theme: Theme) => void }) {
  return (
    <button
      onClick={() => setTheme(theme === "dark" ? "light" : "dark")}
      className="secondary-button inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition"
      aria-label="Toggle theme"
    >
      {theme === "dark" ? <Sun className="h-4 w-4" /> : <Moon className="h-4 w-4" />}
      {theme === "dark" ? "Light" : "Dark"}
    </button>
  );
}

export default function App() {
  const [theme, setThemeState] = useState<Theme>("dark");

  function setTheme(nextTheme: Theme) {
    setThemeState(nextTheme);
    localStorage.setItem("theme", nextTheme);
  }

  useEffect(() => {
    const saved = localStorage.getItem("theme") as Theme | null;
    if (saved === "dark" || saved === "light") {
      setThemeState(saved);
    }
  }, []);

  useEffect(() => {
    document.documentElement.dataset.theme = theme;
  }, [theme]);

  return (
